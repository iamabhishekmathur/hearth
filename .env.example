# ===========================================
# Hearth Configuration
# ===========================================

# Database
DATABASE_URL=postgresql://hearth:hearth@localhost:5432/hearth

# Redis
REDIS_URL=redis://localhost:6379

# Security
SESSION_SECRET=change-me-to-a-random-string
ENCRYPTION_KEY=change-me-to-a-32-byte-hex-string

# LLM Providers (at least one required)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# OLLAMA_BASE_URL=http://localhost:11434

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:8000/api/v1/auth/oauth/google/callback

# App
NODE_ENV=development
API_PORT=8000
WEB_PORT=3000
API_URL=http://localhost:8000
WEB_URL=http://localhost:3000
